// Prisma schema for Chatbot project
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model User {
  uid                   String         @id @default(uuid())
  email                 String         @unique
  name                  String
  password_hash         String
  role                  String
  contact_number        String?
  created_at            DateTime       @default(now())
  updated_at            DateTime       @updatedAt
  is_active             Boolean        @default(true)
  failed_login_attempts Int            @default(0)
  locked_until          DateTime?
  two_fa_enabled        Boolean        @default(false)
  two_fa_secret         String?
  two_fa_backup_codes   String?
  refresh_tokens        RefreshToken[]

  @@index([email])
}

model RefreshToken {
  uid        String   @id @default(uuid())
  user_uid   String
  token_hash String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_uid], references: [uid], onDelete: Cascade)

  @@index([user_uid])
}

model Role {
  uid                String   @id @default(uuid())
  role_name          String   @unique
  can_view_all_chats Boolean  @default(false)
  can_download       Boolean  @default(false)
  can_manage_users   Boolean  @default(false)
  created_at         DateTime @default(now())
}

model ChatBot {
  session_id     String  @id @default(uuid())
  name           String?
  email          String?
  chat_language  String?
  interested_in  String?
  lead_generated Boolean @default(false)

  // Scheduler delete targeting: focus session marker
  is_focus Boolean @default(false)

  created_at DateTime @default(now())
  expires_at DateTime
  chats      Chat[]

  @@index([email])
  @@index([created_at])
  @@index([lead_generated])
  @@index([chat_language])
  @@index([is_focus])
}

model Chat {
  id            Int      @id @default(autoincrement())
  session_id    String
  response_type String
  message_text  String   @db.Text
  timestamp     DateTime @default(now())
  token_count   Int?
  is_visible    Boolean  @default(true)

  // Optional file attachment (image or PDF) stored as binary
  file_name      String?
  file_mime_type String?
  file_data      Bytes?

  // Scheduler delete targeting: welcome message marker
  is_welcome Boolean @default(false)

  chatbot ChatBot @relation(fields: [session_id], references: [session_id], onDelete: Cascade)

  @@index([session_id, timestamp])
  @@index([is_welcome])
}

model SchedulerConfig {
  id       String  @id @default(uuid())
  job_name String
  details  String?

  // Human-friendly scheduling inputs
  run_timing      String?
  cron_expression String

  is_active Boolean @default(true)

  // audit
  created_by String?
  updated_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  executions SchedulerExecutionHistory[]
}

model SchedulerExecutionHistory {
  id           String @id @default(uuid())
  scheduler_id String

  start_time DateTime
  end_time   DateTime?
  status     String

  records_processed Int @default(0)
  records_deleted   Int @default(0)

  error_message String?

  created_at DateTime @default(now())

  scheduler SchedulerConfig @relation(fields: [scheduler_id], references: [id], onDelete: Cascade)

  @@index([scheduler_id])
  @@index([created_at])
  @@index([status])
}

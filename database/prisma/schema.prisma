// Prisma schema for Chatbot project
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model User {
  uid                   String         @id @default(uuid())
  email                 String         @unique
  name                  String
  password_hash         String
  role                  String
  contact_number        String?
  created_at            DateTime       @default(now())
  updated_at            DateTime       @updatedAt
  is_active             Boolean        @default(true)
  failed_login_attempts Int            @default(0)
  locked_until          DateTime?
  refresh_tokens        RefreshToken[]

  @@index([email])
}

model RefreshToken {
  uid        String   @id @default(uuid())
  user_uid   String
  token_hash String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_uid], references: [uid], onDelete: Cascade)

  @@index([user_uid])
}

model Role {
  uid                           String   @id @default(uuid())
  role_name                     String   @unique
  can_view_all_chats            Boolean  @default(false)
  can_download                  Boolean  @default(false)
  can_manage_users              Boolean  @default(false)
  can_access_dashboard          Boolean  @default(false)
  can_access_train_ai           Boolean  @default(false)
  can_access_token_usage        Boolean  @default(false)
  can_access_scheduler          Boolean  @default(false)
  can_access_license_management Boolean  @default(false)
  created_at                    DateTime @default(now())
}

model ChatBot {
  session_id     String  @id @default(uuid())
  name           String?
  email          String?
  chat_language  String?
  interested_in  String?
  lead_generated Boolean @default(false)

  // Scheduler delete targeting: focus session marker
  is_focus Boolean @default(false)

  // User feedback rating (1-5 stars)
  review_rating Int? // 1 to 5

  created_at DateTime @default(now())
  expires_at DateTime
  chats             Chat[]
  avatar_streams    AvatarStream[] @relation("ChatBotAvatarStreams")
  avatar_events     AvatarEvent[]

  @@index([email])
  @@index([created_at])
  @@index([lead_generated])
  @@index([chat_language])
  @@index([is_focus])
}

model Chat {
  id            Int      @id @default(autoincrement())
  session_id    String
  response_type String
  message_text  String   @db.Text
  timestamp     DateTime @default(now())
  token_count   Int?
  is_visible    Boolean  @default(true)

  // Optional file attachment (image or PDF) stored as binary
  file_name      String?
  file_mime_type String?
  file_data      Bytes?

  // Scheduler delete targeting: welcome message marker
  is_welcome Boolean @default(false)

  chatbot ChatBot @relation(fields: [session_id], references: [session_id], onDelete: Cascade)

  @@index([session_id, timestamp])
  @@index([is_welcome])
}

model SchedulerConfig {
  id       String  @id @default(uuid())
  job_name String
  details  String?

  // Human-friendly scheduling inputs
  run_timing      String?
  cron_expression String

  is_active Boolean @default(true)

  // audit
  created_by String?
  updated_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  executions SchedulerExecutionHistory[]
}

model SchedulerExecutionHistory {
  id           String @id @default(uuid())
  scheduler_id String

  start_time DateTime
  end_time   DateTime?
  status     String

  records_processed Int @default(0)
  records_deleted   Int @default(0)

  error_message String?

  created_at DateTime @default(now())

  scheduler SchedulerConfig @relation(fields: [scheduler_id], references: [id], onDelete: Cascade)

  @@index([scheduler_id])
  @@index([created_at])
  @@index([status])
}

model TrainChatbot {
  id            String   @id @default(uuid())
  filename      String
  file_data     Bytes
  ai_response_id String?
  trained_date  DateTime @default(now())
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([created_at])
  @@index([is_active])
}

model TrainChatbotWithUrl {
  id            String   @id @default(uuid())
  page_name     String
  url           String
  ai_response_id String?
  trained_date  DateTime @default(now())
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([created_at])
  @@index([is_active])
  @@index([url])
}

// Avatar / D-ID WebRTC stream management
model AvatarStream {
  id             String   @id @default(uuid())
  session_id     String
  stream_id      String?  // D-ID stream ID
  session_token  String?  // D-ID session ID
  connection_signature String? // Client signature for validation
  avatar_mode    String   @default("text") // text, video, audio
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  closed_at      DateTime?

  chatbot ChatBot     @relation("ChatBotAvatarStreams", fields: [session_id], references: [session_id], onDelete: Cascade)
  events  AvatarEvent[]

  @@index([session_id])
  @@index([stream_id])
  @@index([is_active])
}

// Avatar connection/stream events tracking
model AvatarEvent {
  id             String   @id @default(uuid())
  stream_id      String?  // Optional: not all events have a stream
  session_id     String?
  event_type     String   // stream_created, sdp_sent, ice_candidate, talk_sent, stream_closed, script_loaded, script_closed
  event_data     String?  @db.Text // JSON payload
  created_at     DateTime @default(now())

  avatar_stream AvatarStream? @relation(fields: [stream_id], references: [id], onDelete: Cascade)
  chatbot       ChatBot?      @relation(fields: [session_id], references: [session_id], onDelete: Cascade)

  @@index([stream_id])
  @@index([session_id])
  @@index([event_type])
}

model License {
  id                    Int      @id @default(autoincrement())
  license_id            String   @unique
  client_name           String
  company_address       String?
  company_contact       String?
  company_email         String?
  product_name          String
  deployment_type       String
  max_users             Int
  max_admin_users       Int
  max_token_usage_charge Float @default(0)
  license_type          String
  environment           String
  remarks               String?
  status                String   @default("ACTIVE")

  valid_from            DateTime
  valid_till            DateTime
  created_date          DateTime @default(now())
  assigned_date         DateTime @default(now())

  created_by            String
  created_by_email      String
  license_version       String

  created_timestamp     DateTime @default(now())
  last_modified_timestamp DateTime @updatedAt

  is_tampered           Boolean  @default(false)
  tamper_detected_at    DateTime?

  @@index([status])
  @@index([valid_till])
  @@index([created_by])
  @@index([created_timestamp])
}

model TokenUsage {
  id                String   @id @default(uuid())
  session_id        String?
  call_type         String                   // "llm" | "embedding"
  vendor            String
  model             String
  prompt_tokens     Int      @default(0)
  completion_tokens Int      @default(0)
  total_tokens      Int      @default(0)
  cost_usd          Float    @default(0.0)
  created_at        DateTime @default(now())

  @@index([created_at])
  @@index([vendor, model])
  @@index([session_id])
}
